# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# scraper debug output (HTML dumps)
scraper/data/debug-*.html
scraper/data/*.html
scraper/data/clickables.json
scraper/data/area-elements.json
scraper/data/course-elements.json
scraper/data/toggle-elements.json

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude memory
.claude/

# playwright reports & results
playwright-report/
test-results/

# typescript
*.tsbuildinfo
next-env.d.ts
